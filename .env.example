# ──────────────────────────────────────────────────────────────────
# Backend / Worker / Frontend env configuration
# Copy to `.env` and adjust before `docker compose up`.
# Never commit `.env`.
# ──────────────────────────────────────────────────────────────────

# ── Postgres
POSTGRES_DB=jobs
POSTGRES_USER=jobs
POSTGRES_PASSWORD=change-me-in-prod

# ── Backend ──
# CSV list of valid API keys. Generate strong tokens for production.
API_KEYS=dev-key-1,dev-key-2

# CSV list of allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost

# DSN used by FastAPI (async)
DATABASE_URL=postgresql+asyncpg://jobs:change-me-in-prod@postgres:5432/jobs

# Redis URL (shared by backend SSE pubsub + BullMQ queue)
REDIS_URL=redis://redis:6379/0

LOG_LEVEL=INFO

# ── Worker ──
# DSN used by node-postgres (sync driver string, no +asyncpg)
DATABASE_URL_PG=postgres://jobs:change-me-in-prod@postgres:5432/jobs
WORKER_ID=worker-1
WORKER_FAILURE_RATE=0.1
WORKER_MIN_MS=5000
WORKER_MAX_MS=15000
WORKER_CONCURRENCY=4

# ── Frontend ──
# Baked into the Vite bundle at build time. NOT a secret store —
# rotate API keys server-side for real users.
VITE_API_BASE=/api
VITE_EVENTS_BASE=/events
VITE_API_KEY=dev-key-1
